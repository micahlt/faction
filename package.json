{
  "name": "faction",
  "version": "0.1.0",
  "description": "Simple group messaging software",
  "homepage": "https://github.com/micahlt/faction#readme",
  "bugs": {
    "url": "https://github.com/micahlt/faction/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/micahlt/faction.git"
  },
  "license": "MIT",
  "author": "",
  "workspaces": [
    "apps/*"
  ],
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run dev -w apps/server",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md,css}\"",
    "lint": "eslint \"apps/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"apps/**/*.{js,jsx}\" --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  }
}
