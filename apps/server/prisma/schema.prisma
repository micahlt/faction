// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String  @id @default(uuid())
  username String  @unique
  email    String  @unique
  password String
  nickname String  @default("")
  imageUrl String?

  factions   Faction[] @relation("FactionMembers")
  ownerships Faction[] @relation("OwnedFactions")
  messages   Message[]
  invites    Invite[]

  reactions Reaction[]
}

// A faction is pretty much the same as a discord server
model Faction {
  id      String  @id @default(uuid())
  name    String
  iconUrl String?
  ownerId String

  owner   User     @relation(fields: [ownerId], references: [id], name: "OwnedFactions", onDelete: Cascade)
  topics  Topic[]
  invites Invite[]
  members User[]   @relation("FactionMembers")
}

// A topic is the same as a discord channel
model Topic {
  id        String    @id @default(uuid())
  name      String
  order     Int
  factionId String
  faction   Faction   @relation(fields: [factionId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  topicId  String @map("topicId")
  topic    Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  reactions Reaction[]
}

model Reaction {
  messageId String
  userId    String
  emoji     String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
  @@index([messageId])
  @@index([messageId, emoji])
  @@index([userId])
}

model Invite {
  code      String    @id @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  authorId  String
  author    User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  factionId String
  faction   Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)
}
